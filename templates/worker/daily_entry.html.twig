{% extends 'base.html.twig' %}

{% block title %}Saisie Journalière - My Bakery{% endblock %}

{% block body %}
<div class="container-fluid mt-4 mb-5 pb-5 px-lg-5">
    
    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show shadow-sm text-center" role="alert">
            <i class="fas fa-check-circle fa-2x mb-2"></i><br>
            <strong>Génial!</strong> {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}

    {% for message in app.flashes('warning') %}
        <div class="alert alert-warning alert-dismissible fade show text-center shadow-sm" role="alert">
            <i class="fas fa-undo-alt me-2"></i> {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show text-center shadow-sm" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i> {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}

    <div class="row gx-lg-5">

        <!-- Left Column: Form -->
        <div class="col-lg-5 mb-4">
            <div class="card shadow border-0 rounded-4 mb-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                    <h2 class="title-brown h4 fw-bold">Étape 1 : Saisir un produit</h2>
                    <p class="text-muted small">Sélectionnez le produit dans la liste et validez ses statistiques réelles.</p>
                </div>
                <div class="card-body p-4">
                    {% if products|length > 0 %}
                        <form method="post">
                            <input type="hidden" name="date" value="{{ 'now'|date('Y-m-d') }}">

                            <div class="mb-4">
                                <label class="form-label text-secondary fw-semibold">Produit à déclarer</label>
                                <select name="product_id" class="form-select border-2 bg-light py-2" required>
                                    <option value="" disabled selected>-- Sélectionnez un produit --</option>
                                    {% for p in products %}
                                        <option value="{{ p.id }}">{{ p.name }} (Prix: {{ p.price }} TND)</option>
                                    {% endfor %}
                                </select>
                            </div>
                            
                            <div class="row gx-3">
                                <div class="col-sm-6 mb-4">
                                    <label class="form-label text-secondary fw-semibold">
                                        <i class="fas fa-fire me-1 text-primary"></i> Qté Produite
                                    </label>
                                    <input type="number" name="quantity_produced" class="form-control border-2 bg-light py-2" placeholder="Sorti du four" required min="0">
                                </div>
                                
                                <div class="col-sm-6 mb-4">
                                    <label class="form-label text-secondary fw-semibold">
                                        <i class="fas fa-shopping-basket me-1 text-success"></i> Qté Vendue
                                    </label>
                                    <input type="number" name="quantity_sold" class="form-control border-2 bg-light py-2" placeholder="Vendu au client" required min="0">
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label text-secondary fw-semibold">
                                    <i class="fas fa-coins me-1 text-warning"></i> Chiffre d'affaire (Espèce)
                                </label>
                                <div class="input-group">
                                    <input type="number" step="0.01" name="announced_total" class="form-control border-2 bg-light py-2 px-3" placeholder="Argent reçu de ce produit" required min="0">
                                    <span class="input-group-text bg-white border-2 text-muted fw-bold">TND</span>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-primary btn-bakery w-100 py-3 fw-bold shadow-sm rounded-3">
                                Sauvegarder <i class="fas fa-plus ms-1"></i>
                            </button>
                        </form>
                    {% else %}
                        <div class="text-center py-4">
                            <i class="fas fa-check-circle fa-4x text-success mb-3 opacity-50"></i>
                            <h4 class="text-muted fw-bold">Produits Terminés !</h4>
                            <p class="text-muted">Vous avez renseigné toutes les données du jour.</p>
                        </div>
                    {% endif %}
                </div>
            </div>
            
            <!-- Global Checkout Section -->
            {% if todayLogs|length > 0 %}
            <div class="card border-0 bg-transparent">
                <div class="card-body p-0">
                    <form action="{{ path('worker_checkout') }}" method="post" enctype="multipart/form-data" class="p-4 border border-2 border-warning rounded-4 bg-white shadow-sm">
                        <h4 class="fw-bold title-brown"><i class="fas fa-camera text-warning"></i> Étape 2 : Clôturer la Caisse</h4>
                        <p class="text-muted small mb-4">Votre service est terminé ? Prenez une seule photo globale de votre bloc de note papier ou du tiroir caisse, et validez votre journée complète.</p>
                        
                        <div class="mb-4">
                            <input type="file" name="daily_note_image" class="form-control border-2 bg-light" accept="image/*" capture="environment" required>
                            <small class="form-text text-muted">Obligatoire pour valider la journée.</small>
                        </div>
                        <button type="submit" class="btn btn-warning w-100 py-3 fw-bold shadow-sm rounded-3 text-dark">
                            <i class="fas fa-door-closed me-2"></i> Terminer mon service
                        </button>
                    </form>
                </div>
            </div>
            {% endif %}

        </div>

        <!-- Right Column: Current Log -->
        <div class="col-lg-7">
            <div class="card shadow-sm border-0 rounded-4 bg-white h-100">
                <div class="card-header bg-transparent border-bottom-0 pt-4 pb-2 px-4 d-flex justify-content-between align-items-center">
                    <h2 class="title-brown h5 fw-bold mb-0">Historique des déclarations (Aujourd'hui)</h2>
                    <span class="badge bg-secondary rounded-pill">{{ todayLogs|length }} Produits</span>
                </div>
                <div class="card-body px-4 pb-4">
                    {% if todayLogs|length > 0 %}
                        <div class="table-responsive rounded-3">
                            <table class="table table-hover align-middle mb-0 border">
                                <thead class="table-light text-secondary small">
                                    <tr>
                                        <th class="ps-3 border-0">Produit Renseigné</th>
                                        <th class="text-center border-0">Produit</th>
                                        <th class="text-center border-0">Vendu</th>
                                        <th class="text-end border-0">Espèce</th>
                                        <th class="text-center border-0" style="width: 50px;">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for log in todayLogs %}
                                    <tr>
                                        <td class="ps-3 fw-medium border-0 border-bottom">
                                            {{ log.product.name }}<br>
                                            <small class="text-success"><i class="fas fa-check-double"></i> Enregistré</small>
                                        </td>
                                        <td class="text-center border-0 border-bottom">
                                            <span class="badge bg-primary bg-opacity-10 text-primary">{{ prodLogsMapped[log.product.id] ?? 0 }}</span>
                                        </td>
                                        <td class="text-center border-0 border-bottom">
                                            <span class="badge bg-success bg-opacity-10 text-success">{{ log.quantitySold }}</span>
                                        </td>
                                        <td class="text-end fw-bold border-0 border-bottom">
                                            {{ log.announcedTotal }} <small class="text-muted fw-normal">TND</small>
                                        </td>
                                        <td class="text-center border-0 border-bottom">
                                            <form action="{{ path('worker_entry_delete', {id: log.id}) }}" method="post" onsubmit="return confirm('Êtes-vous sûr de vouloir annuler la ligne pour {{ log.product.name }} ?');">
                                                <button type="submit" class="btn btn-sm btn-outline-danger border-0 rounded-circle" title="Annuler (Undo)">
                                                    <i class="fas fa-undo"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% else %}
                        <div class="d-flex flex-column align-items-center justify-content-center h-100 py-5 text-muted opacity-50">
                            <i class="fas fa-clipboard-list fa-4x mb-3 text-secondary"></i>
                            <p class="fs-5">Aucune déclaration commencée pour l'instant.</p>
                            <p class="small text-center">Commencez par ajouter les produits à gauche.</p>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

    </div>
</div>
{% endblock %}
