{% extends 'base.html.twig' %}

{% block title %}Nouvel Employé - My Bakery{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h3 title-brown fw-bold mb-0">Ajouter un Employé</h1>
                <a href="{{ path('admin_user_index') }}" class="btn btn-outline-secondary btn-sm"><i class="fas fa-arrow-left me-1"></i> Retour</a>
            </div>

            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4 p-md-5">
                    <form method="post">
                        
                        <div class="mb-4">
                            <label class="form-label text-secondary fw-bold">Identifiant / Email de Connexion</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="fas fa-user text-muted"></i></span>
                                <input type="text" name="username" class="form-control border-0 bg-light py-2" required placeholder="vendeur@mybakery.com">
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label text-secondary fw-bold">Mot de Passe Provisoire</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="fas fa-lock text-muted"></i></span>
                                <input type="password" name="password" class="form-control border-0 bg-light py-2" required placeholder="********">
                            </div>
                            <small class="text-muted">Il servira pour la première connexion.</small>
                        </div>

                        <div class="mb-4">
                            <label class="form-label text-secondary fw-bold">Rôle dans l'Entreprise</label>
                            <select name="role" class="form-select border-0 bg-light py-2 shadow-sm" required>
                                <option value="ROLE_WORKER" selected>Vendeur (Accès Limité Saisie Journalière)</option>
                                <option value="ROLE_ADMIN">Gérant (Accès Total Dashboard Manager)</option>
                            </select>
                        </div>

                        <button type="submit" class="btn btn-primary btn-bakery w-100 py-3 mt-2 fw-bold rounded-3">
                            Créer le Compte <i class="fas fa-save ms-1"></i>
                        </button>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}
