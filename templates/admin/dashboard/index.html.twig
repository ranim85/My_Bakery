{% extends 'base.html.twig' %}

{% block title %}Dashboard - Admin My Bakery{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom flex-wrap">
        <h1 class="title-brown d-flex align-items-center mb-3 mb-md-0">
            Manager Dashboard
            {% if currentDateFilter == 'today' %}
                <span class="badge bg-primary ms-3 fs-6 rounded-pill">Today</span>
            {% elseif currentDateFilter == 'month' %}
                <span class="badge bg-info ms-3 fs-6 rounded-pill">This Month</span>
            {% elseif currentDateFilter == 'year' %}
                <span class="badge bg-warning text-dark ms-3 fs-6 rounded-pill">This Year</span>
            {% elseif currentDateFilter != 'all' %}
                <span class="badge bg-secondary ms-3 fs-6 rounded-pill">{{ currentDateFilter|date('d/m/Y') }}</span>
            {% else %}
                <span class="badge bg-dark ms-3 fs-6 rounded-pill">All Time</span>
            {% endif %}
        </h1>
        
        <div class="d-flex align-items-center gap-2">
            <form method="get" class="d-flex align-items-center bg-white p-1 rounded-3 shadow-sm border">
                <input type="date" name="date" class="form-control border-0" style="width: 140px;" value="{% if currentDateFilter != 'all' and currentDateFilter != 'today' and currentDateFilter != 'month' and currentDateFilter != 'year' %}{{ currentDateFilter }}{% elseif currentDateFilter == 'today' %}{{ 'now'|date('Y-m-d') }}{% endif %}" onchange="this.form.submit()" title="Choose a specific day">
                <div class="mx-1 text-muted fw-bold d-none d-lg-block">OR</div>
                <button type="submit" name="date" value="today" class="btn btn-sm {% if currentDateFilter == 'today' %}btn-primary{% else %}btn-light{% endif %} fw-bold ms-1" title="Show Today">Today</button>
                <button type="submit" name="date" value="month" class="btn btn-sm {% if currentDateFilter == 'month' %}btn-info text-white{% else %}btn-light{% endif %} fw-bold ms-1" title="Show Current Month">Month</button>
                <button type="submit" name="date" value="year" class="btn btn-sm {% if currentDateFilter == 'year' %}btn-warning text-dark{% else %}btn-light{% endif %} fw-bold ms-1" title="Show Current Year">Year</button>
                <button type="submit" name="date" value="all" class="btn btn-sm {% if currentDateFilter == 'all' %}btn-dark{% else %}btn-light{% endif %} fw-bold ms-1" title="Show Everything">All</button>
            </form>
            <div class="vr mx-1"></div>
            <a href="{{ path('admin_product_index') }}" class="btn btn-outline-secondary"><i class="fas fa-bread-slice me-1"></i> Products</a>
            <a href="{{ path('admin_purchase_index') }}" class="btn btn-outline-secondary"><i class="fas fa-receipt me-1"></i> Expenses</a>
        </div>
    </div>

    <div class="row text-center mb-5">
        <div class="col-md-3">
            <div class="card shadow-sm border-0 stat-card">
                <div class="card-body">
                    <h5 class="card-title text-muted">Expected Income</h5>
                    <h2 class="text-primary">{{ totalCalculated | number_format(2) }} TND</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 stat-card">
                <div class="card-body">
                    <h5 class="card-title text-muted">Declared Income</h5>
                    <h2 class="text-success">{{ totalAnnounced | number_format(2) }} TND</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 stat-card">
                <div class="card-body">
                    <h5 class="card-title text-muted">Total Expenses</h5>
                    <h2 class="text-danger">- {{ totalExpenses | number_format(2) }} TND</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card shadow-sm border-0 stat-card">
                <div class="card-body">
                    <h5 class="card-title text-muted">Discrepancy (Missing)</h5>
                    <h2 class="{% if totalDiscrepancy > 0 %}text-danger{% else %}text-muted{% endif %}">
                        {{ totalDiscrepancy | number_format(2) }} TND
                    </h2>
                </div>
            </div>
        </div>
    </div>

    {% if discrepancies|length > 0 %}
    <div class="alert alert-danger shadow border-0 mt-4 rounded-4">
        <h4 class="alert-heading text-danger fw-bold"><i class="fas fa-exclamation-triangle me-2"></i> Financial Discrepancies Detected!</h4>
        <p class="mb-3 text-dark">There are differences between the system's calculated expectations and the money declared by your workers. Please investigate the entries below:</p>
        <div class="table-responsive bg-white rounded-3 p-3 shadow-sm border border-danger border-opacity-25">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-secondary small">
                    <tr>
                        <th>Date</th>
                        <th>Worker Identity</th>
                        <th>Product</th>
                        <th class="text-end">Expected (System)</th>
                        <th class="text-end">Declared (Worker)</th>
                        <th class="text-end">Missing Status</th>
                    </tr>
                </thead>
                <tbody>
                {% for issue in discrepancies %}
                    <tr>
                        <td class="text-muted"><i class="fas fa-calendar-alt me-1"></i>{{ issue.log.date|date('Y-m-d') }}</td>
                        <td class="fw-bold"><i class="fas fa-user-circle text-primary me-1"></i>{{ issue.log.worker ? issue.log.worker.userIdentifier : 'Unknown Employee' }}</td>
                        <td><span class="badge bg-secondary bg-opacity-10 text-dark">{{ issue.log.product.name }}</span></td>
                        <td class="text-end fw-medium">{{ issue.log.calculatedTotal|number_format(2) }} <small class="text-muted">TND</small></td>
                        <td class="text-end fw-bold">{{ issue.log.announcedTotal|number_format(2) }} <small class="text-muted">TND</small></td>
                        <td class="text-end">
                            {% if issue.difference > 0 %}
                                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger px-3 py-2 fs-6 rounded-pill">
                                    <i class="fas fa-arrow-down me-1"></i> Missing {{ issue.difference|number_format(2) }} TND
                                </span>
                            {% else %}
                                <span class="badge bg-warning bg-opacity-10 text-warning border border-warning px-3 py-2 fs-6 rounded-pill">
                                    <i class="fas fa-arrow-up me-1"></i> Surplus {{ (issue.difference * -1)|number_format(2) }} TND
                                </span>
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% endif %}
</div>
{% endblock %}
