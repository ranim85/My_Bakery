{% extends 'base.html.twig' %}

{% block title %}Add Product - My Bakery{% endblock %}

{% block body %}
<div class="container mt-4 mb-5 pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                    <h2 class="title-brown h4 fw-bold">Create New Product</h2>
                </div>
                <div class="card-body p-4">
                    <form method="post">
                        <div class="mb-3">
                            <label class="form-label text-secondary fw-semibold">Product Name</label>
                            <input type="text" name="name" class="form-control border-2 bg-light" required placeholder="Ex: Baguette">
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label text-secondary fw-semibold">Category</label>
                            <input type="text" name="category" class="form-control border-2 bg-light" required placeholder="Ex: Bread, Pastry">
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-secondary fw-semibold">Price (TND)</label>
                            <div class="input-group">
                                <input type="number" step="0.01" name="price" class="form-control border-2 bg-light" required min="0">
                                <span class="input-group-text bg-white border-2">TND</span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label text-secondary fw-semibold">Description</label>
                            <textarea name="description" class="form-control border-2 bg-light" rows="3"></textarea>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a href="{{ path('admin_product_index') }}" class="btn btn-outline-secondary py-2 border-2">Cancel</a>
                            <button type="submit" class="btn btn-primary btn-bakery py-2 px-4 fw-bold shadow-sm">Save Product</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
