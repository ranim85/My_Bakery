{% extends 'base.html.twig' %}

{% block title %}Manage Products - My Bakery{% endblock %}

{% block body %}
<div class="container-fluid mt-4 mb-5 pb-5 px-lg-5">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <h1 class="title-brown h3 fw-bold"><i class="fas fa-bread-slice me-2"></i>Product Catalog</h1>
        <a href="{{ path('admin_product_new') }}" class="btn btn-primary btn-bakery fw-bold shadow-sm">
            <i class="fas fa-plus me-1"></i> Add Product
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive rounded-4">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-secondary">
                        <tr>
                            <th class="ps-4">Product Name</th>
                            <th>Category</th>
                            <th>Description</th>
                            <th>Price</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for product in products %}
                        <tr>
                            <td class="ps-4 fw-bold text-dark">{{ product.name }}</td>
                            <td><span class="badge bg-secondary bg-opacity-10 text-secondary">{{ product.category }}</span></td>
                            <td class="text-muted small">{{ product.description|default('-')|slice(0, 50) }}</td>
                            <td class="fw-bold text-success">{{ product.price|number_format(2) }} <small class="text-muted fw-normal">TND</small></td>
                            <td class="text-end pe-4">
                                <a href="{{ path('admin_product_edit', {'id': product.id}) }}" class="btn btn-sm btn-outline-primary"><i class="fas fa-edit"></i> Edit</a>
                                
                                <form method="post" action="{{ path('admin_product_delete', {'id': product.id}) }}" style="display:inline-block" onsubmit="return confirm('Are you sure you want to delete this product?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
                                    <button class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="fas fa-box-open fa-3x mb-3 opacity-50"></i>
                                <p>No products found in the catalog.</p>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
